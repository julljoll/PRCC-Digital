# Variables de entorno para PRCC Digital

# Clave secreta para Flask (cambiar en producción)
SECRET_KEY=tu-clave-secreta-muy-segura-2024

# URL de conexión a Neon Database
# Obtener en: https://console.neon.tech
DATABASE_URL=postgresql://usuario:password@ep-xxx.region.aws.neon.tech/prcc_db?sslmode=require

# Modo de depuración (False en producción)
DEBUG=False

# Entorno (local, development, production)
ENVIRONMENT=local
