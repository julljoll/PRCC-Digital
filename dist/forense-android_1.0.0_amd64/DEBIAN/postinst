#!/bin/bash
# Script post-instalación para forense-android
# Instala automáticamente todas las dependencias Python y herramientas forenses

set -e

echo "🔧 Configurando Sistema Forense Android..."

# Crear directorio de datos del usuario
mkdir -p /var/lib/forense-android/casos
chmod 700 /var/lib/forense-android

# Crear directorios de configuración
mkdir -p /etc/forense-android
mkdir -p /usr/share/forense-android

# Crear entorno virtual para la aplicación
echo "📦 Creando entorno virtual Python..."
python3 -m venv /usr/share/forense-android/venv
source /usr/share/forense-android/venv/bin/activate

# Instalar dependencias Python desde requirements.txt
echo "📥 Instalando dependencias Python (PyQt6, reportlab, Pillow)..."
pip install --upgrade pip --quiet
pip install PyQt6>=6.6.0 reportlab>=4.0.0 Pillow>=10.0.0 --quiet

# Clonar e instalar Andriller desde GitHub (última versión)
echo "🔍 Instalando Andriller desde GitHub..."
if [ ! -d "/opt/andriller" ]; then
    git clone --depth 1 https://github.com/denysYevstafeyev/andriller.git /opt/andriller
    cd /opt/andriller
    pip install -e . --quiet
    ln -sf /opt/andriller/andriller.py /usr/local/bin/andriller
    chmod +x /usr/local/bin/andriller
else
    echo "  ℹ️  Andriller ya está instalado, actualizando..."
    cd /opt/andriller
    git pull --quiet
    pip install -e . --quiet --upgrade
fi

# Clonar e instalar ALEAPP desde GitHub (última versión)
echo "🔍 Instalando ALEAPP desde GitHub..."
if [ ! -d "/opt/aleapp" ]; then
    git clone --depth 1 https://github.com/abrignoni/ALEAPP.git /opt/aleapp
    cd /opt/aleapp
    pip install -r requirements.txt --quiet
    ln -sf /opt/aleapp/aleapp.py /usr/local/bin/aleapp
    chmod +x /usr/local/bin/aleapp
else
    echo "  ℹ️  ALEAPP ya está instalado, actualizando..."
    cd /opt/aleapp
    git pull --quiet
    pip install -r requirements.txt --quiet --upgrade
fi

# Desactivar entorno virtual temporal
deactivate 2>/dev/null || true

# Configurar permisos correctos
chown -R root:root /usr/share/forense-android
chmod -R 755 /usr/share/forense-android

# Actualizar caché de aplicaciones
update-desktop-database 2>/dev/null || true

echo ""
echo "✅ Sistema Forense Android instalado correctamente."
echo ""
echo "Componentes instalados:"
echo "  • Aplicación principal: /usr/share/forense-android"
echo "  • Entorno Python: /usr/share/forense-android/venv"
echo "  • Andriller: /opt/andriller (desde GitHub)"
echo "  • ALEAPP: /opt/aleapp (desde GitHub)"
echo ""
echo "Para iniciar la aplicación, ejecute:"
echo "  forense-android"
echo ""
echo "O busque 'Sistema Forense Android' en el menú de aplicaciones."
echo ""
